<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="@color/control_bar_background"
    app:cardCornerRadius="6dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- Team color accent bar -->
        <View
            android:id="@+id/teamColorBar"
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@color/player_blue" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/unitName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/unitDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/teal_200"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/unitWeapon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/neutral_gray"
                android:textSize="10sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRemoveUnit"
            style="@style/GameButtonStyle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/cd_custom_remove_unit"
            android:padding="0dp"
            android:text="✕"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
