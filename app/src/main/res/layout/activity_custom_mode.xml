<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_gray"
    android:orientation="horizontal"
    android:padding="16dp"
    tools:context=".CustomModeActivity">

    <!-- Left panel: Configuration options -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/custom_mode_title"
            android:textColor="@color/accent_gold"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Map Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_map_label"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerMapLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/cd_custom_map_select" />

        <!-- Objective Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_objective_label"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerObjective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/cd_custom_objective_select" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnSaveConfig"
                style="@style/GameButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/cd_custom_save"
                android:text="@string/custom_save" />

            <Button
                android:id="@+id/btnLoadConfig"
                style="@style/GameButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:contentDescription="@string/cd_custom_load"
                android:text="@string/custom_load" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStartBattle"
            style="@style/GameButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/cd_custom_start"
            android:text="@string/custom_start_battle" />

        <Button
            android:id="@+id/btnBack"
            style="@style/GameButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cd_back"
            android:text="@string/back" />
    </LinearLayout>

    <!-- Right panel: Unit lists -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <!-- Player Units Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtPlayerUnitCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/custom_player_units_default"
                    android:textColor="@color/player_blue"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnAddPlayerUnit"
                    style="@style/GameButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:contentDescription="@string/cd_custom_add_player"
                    android:text="@string/custom_add_unit"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPlayerUnits"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Enemy Units Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtEnemyUnitCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/custom_enemy_units_default"
                    android:textColor="@color/enemy_red"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnAddEnemyUnit"
                    style="@style/GameButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:contentDescription="@string/cd_custom_add_enemy"
                    android:text="@string/custom_add_unit"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerEnemyUnits"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
